# --- 0G Galileo Testnet ---
GALILEO_RPC_URL=https://evmrpc-testnet.0g.ai
GALILEO_CHAIN_ID=16602
GALILEO_EXPLORER_URL=https://chainscan-galileo.0g.ai

# Primary EOA used by broker (ledger fund + provider auth + storage signer + facilitator settle)
PRIMARY_PRIVATE_KEY=0x

# Deployed contract addresses (populated after Phase 6 deploy)
GALILEO_ATOKEN_ADDRESS=0x
GALILEO_GATEWAY_ADDRESS=0x

# --- 0G Compute ---
# "live" hits real broker; "mock" uses deterministic deny-list — default
ZG_COMPUTE_MODE=mock
# initial broker ledger balance (OG, default 3 — contract minimum per
# 0g-compute-ts-starter-kit; lower values revert)
ZG_LEDGER_INITIAL_OG=3
# per-provider sub-account funding (OG, default 1.0 per starter-kit)
ZG_PROVIDER_FUND_OG=1.0

# --- 0G Storage ---
# "live" persists receipts to 0G Storage; "mock" → JsonReceiptStore — default
ZG_STORAGE_MODE=mock
ZG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# --- facilitator + demo merchant ports ---
FACILITATOR_PORT=4021
FACILITATOR_URL=http://localhost:4021
DEMO_MERCHANT_PORT=4020
CONSOLE_ORIGIN=http://localhost:3000

# Merchant address that receives payments
MERCHANT_ADDRESS=0x

# MCP agent wallet (for local pay-and-call demo)
MCP_WALLET_PRIVATE_KEY=0x
