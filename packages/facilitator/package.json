{
  "name": "@agentcheckout/facilitator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./verify": "./src/verify.ts",
    "./settle": "./src/settle.ts",
    "./viem": "./src/viem.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
